{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Next.js (dev)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal",
            "port": 9229,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "outputCapture": "std",
            "sourceMaps": true
        }
    ]
}